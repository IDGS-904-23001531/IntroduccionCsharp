@model IntroduccionC_.Models.Multiplicacion

<div class="container">
    <div class="row">

        <div class="col-lg-6">

            <form action="/Multiplicacion/Calcular" method="post">

                <label>Numero 1:</label>
                <input type="text" name="num1" />
                <br />

                <label>Numero 2:</label>
                <input type="text" name="num2" />
                <br />

                <input type="submit" value="Calcular" />

            </form>

        </div>

        <div class="col-lg-6">

            <br />

            <h2>Proceso:</h2>
            <h3>@Html.DisplayFor(model => model.mulsum)</h3>

            <h2>Resultado:</h2>
            <h3>@Html.DisplayFor(model => model.res)</h3>

        </div>

    </div>
</div>